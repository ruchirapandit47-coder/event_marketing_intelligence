# Google GenAI Settings
# If GOOGLE_API_KEY is provided, Gemini developer API key will be used.
# If not provided, the SDK will fall back to Vertex AI with Google Cloud Application Default Credentials.
GOOGLE_API_KEY=

# Project/Location settings (only required when using Vertex AI / Google Cloud)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Default model configuration
# E.g., gemini-2.5-flash or gemini-1.5-flash
GEMINI_MODEL=gemini-2.5-flash
